# Google AdSense (public marketing site only). Get ca-pub-… from AdSense → Account → Account information.
# After approval, turn on Auto ads in AdSense or create display units and add their snippets.
# When set, the site loads Consent Mode v2 (default denied) and a cookie banner on marketing pages.
NEXT_PUBLIC_ADSENSE_CLIENT=

# Optional: canonical site URL for Open Graph / metadataBase (e.g. https://mangalorehomes.in)
# NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Spring Boot API (required for live data). Must match CORS on the backend (see backend cors.allowedOrigins).
NEXT_PUBLIC_API_BASE_URL=http://localhost:8080
